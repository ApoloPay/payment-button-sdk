{
  "name": "@apolopay-sdk/vue",
  "version": "1.2.0",
  "description": "Vue Payment Button Adapter",
  "repository": {
    "type": "git",
    "url": "https://github.com/ApoloPay/payment-button-sdk"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external vue",
    "dev": "tsup src/index.tsx --format esm,cjs --dts --watch --external vue"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@apolopay-sdk/ui": "workspace:*"
  },
  "devDependencies": {
    "tsup": "8.0.0",
    "typescript": "5.4.5",
    "vue": "3.0.0"
  },
  "peerDependencies": {
    "vue": "3.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  }
}